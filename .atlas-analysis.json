  "keyFeatures": [
    "Ultra-fast local music generation (under 2s on A100, under 10s on RTX 3090)",
    "Hybrid LM+DiT architecture with Chain-of-Thought reasoning",
    "Multi-platform support (CUDA, ROCm, Intel XPU, Apple MPS/MLX, CPU)",
    "Commercial-grade quality between Suno v4.5 and v5",
    "Flexible duration from 10 seconds to 10 minutes",
    "Advanced editing: cover generation, repaint, multi-track, vocal-to-BGM",
    "LoRA training from just 8 songs in 1 hour on RTX 3090",
    "50+ language support for lyrics and vocals",
    "REST API and Python SDK for integration",
    "Gradio UI, CLI, and Studio DAW-like interface"
  ],
  "publicApiSurface": [
    "acestep (CLI entry point)",
    "acestep-api (REST API server)",
    "acestep-download (model downloader)",
    "GenerationParams (parameter configuration dataclass)",
    "GenerationConfig (generation settings)",
    "generate_music() (main generation function)",
    "AceStepHandler (model handler)",
    "LLMHandler (5Hz LM handler)",
    "POST /release_task (create generation task)",
    "POST /query_result (query task status)",
    "POST /format_input (LLM text formatting)",
    "POST /create_random_sample (LLM random generation)",
    "GET /v1/models (list models)",
    "GET /v1/audio (download audio)",
    "train.py (LoRA training script)"
  ]
